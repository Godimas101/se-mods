	<CubeBlocks>
		<Definition xsi:type="MyObjectBuilder_SurvivalKitDefinition">
			<Id>
				<TypeId>SurvivalKit</TypeId>
				<SubtypeId>SurvivalKitLargeReskin</SubtypeId>
			</Id>
			<DisplayName>DisplayName_Block_SurvivalKitReskin</DisplayName>
