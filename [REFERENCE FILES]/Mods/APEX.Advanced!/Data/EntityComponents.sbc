		<!-- Small Algae Farm -->
		<EntityComponent xsi:type="MyObjectBuilder_SolarFoodGeneratorDefinition">
			<Id>
				<TypeId>SolarFoodGenerator</TypeId>
				<SubtypeId>SmallAlgae</SubtypeId>
			</Id>
			<ItemDefinitionId>
				<TypeId>PhysicalObject</TypeId>
				<SubtypeId>Algae</SubtypeId>
			</ItemDefinitionId>
			<ProductionTime>900</ProductionTime>
			<Quantity>1</Quantity>
			<PowerConsumption>0.004</PowerConsumption>
			<ResourceSinkGroup>Factory</ResourceSinkGroup>
		</EntityComponent>
		<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
			<Id>
				<TypeId>Inventory</TypeId>
				<SubtypeId>SmallAlgaeFarm</SubtypeId>
			</Id>
			<Volume>0.010</Volume>
			<InputConstraint Whitelist="true" Description="DisplayName_InventoryConstraint_PersonalItems" Icon="Textures\GUI\Icons\Filter_Algae.dds">
				<Entry>
					<TypeId>PhysicalObject</TypeId>
					<SubtypeId>Algae</SubtypeId>
				</Entry>
			</InputConstraint>
			<CanSend>true</CanSend>
			<CanReceive>true</CanReceive>
		</EntityComponent>
