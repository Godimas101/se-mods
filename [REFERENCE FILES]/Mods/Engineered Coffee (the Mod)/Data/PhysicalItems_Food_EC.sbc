	<PhysicalItems>
		<PhysicalItem xsi:type="MyObjectBuilder_ConsumableItemDefinition">
			<Id>
				<TypeId>ConsumableItem</TypeId>
				<SubtypeId>MealPack_RoastedCoffee</SubtypeId>
			</Id>
			<DisplayName>Meal Pack (Roasted Eng. Coffee)</DisplayName>
			<Description>This artisanal machine-processed dark roast is the perfect blend of rich carmel flavor and Martian dirt.
Over-Roasted to perfection in a repurposed hydrogen engine. Tastes like productivity.

Heal Value: 2%
Fill Value: 2%
Charge Value: 4%</Description>
			<Icon>Textures\GUI\Icons\Items\MealPack_Coffee.dds</Icon>
			<Size>
				<X>0.15</X>
				<Y>0.15</Y>
				<Z>0.15</Z>
			</Size>
			<Mass>1.5</Mass>
			<Volume>1.25</Volume>
			<Model>Models\Items\MealPack_coffee.mwm</Model>
			<PhysicalMaterial>Metal</PhysicalMaterial>
			<Stats>
				<Stat Name="Health" Value ="0.002" Time="10"/>
				<Stat Name="Food" Value="0.002" Time="10"/>
				<Stat Name="BatteryCharge" Value ="0.004" Time="10"/>
			</Stats>
			<UseSound>ArcPlayEat</UseSound>
			<ExtraInventoryTooltipLineId>Heal Value: 2%
Fill Value: 2%
Charge Value: 4%
			
Artisanal machine-processed dark roast,
perfect blend of rich carmel flavor and Martian dirt
Made under highly conrtolled conditions.</ExtraInventoryTooltipLineId>
			<MinimumOfferAmount>1</MinimumOfferAmount>
			<MaximumOfferAmount>4</MaximumOfferAmount>
			<CanPlayerOrder>true</CanPlayerOrder>
		</PhysicalItem>
		
