					<ModelPath>Models\Environment\Farming\CoffeePlant_GS_2.mwm</ModelPath>
				</GrowthStage>
					<GrowthStage>
					<MinCompletionPercentage>99.99</MinCompletionPercentage>
					<MaxCompletionPercentage>100</MaxCompletionPercentage>
					<ModelPath>Models\Environment\Farming\CoffeePlant_GS_3.mwm</ModelPath>
				</GrowthStage>
			</GrowthStages>
			<DeadPlantModelPath>Models\Environment\Farming\crop_fruit_001_GS_4.mwm</DeadPlantModelPath>

			<MinimalPricePerUnit>100</MinimalPricePerUnit>
